# انسخ هذا الملف إلى .env ثم ضع القيم الحقيقية

# التوكن الذي تحصل عليه من @BotFather في تلكرام
BOT_TOKEN=your_bot_token_here

# معرّف المحادثة (Chat ID) الذي تريد استقبال الطلبات فيه
CHAT_ID=your_chat_id_here

# نص عشوائي سري يُستخدم لتشفير بيانات منع التكرار (غيّره لأي نص عشوائي طويل)
HASH_SALT=change-this-to-any-random-secret-string

# منفذ تشغيل الخادم (اختياري، القيمة الافتراضية 3000)
PORT=3000
