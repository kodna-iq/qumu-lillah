<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>قوموا لله — استمارة تقديم الصور</title>
<link rel="icon" href="/assets/logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Lalezar&family=Cairo:wght@500;700;800&family=Tajawal:wght@300;400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#000000;
    --surface:#0d0d0d;
    --surface-2:#161616;
    --red:#e2211b;
    --red-dark:#a3160f;
    --white:#ffffff;
    --text-muted:#b3aeaa;
    --border:#2a2a2a;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--white);
    font-family:'Tajawal', sans-serif;
    line-height:1.7;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  /* ---------- top accent bar ---------- */
  .accent-bar{height:6px; background:var(--red);}

  /* ---------- hero ---------- */
  .hero{
    position:relative;
    max-width:900px;
    margin:0 auto;
    padding:64px 24px 40px;
    text-align:center;
    overflow:hidden;
  }
  .hero .arch{
    position:absolute;
    top:-40px; left:50%;
    transform:translateX(-50%);
    width:340px; height:420px;
    background:var(--red);
    border-radius:170px 170px 0 0;
    opacity:.14;
    z-index:0;
  }
  .hero .logo-wrap{position:relative; z-index:1;}
  .hero img.logo{
    width:min(92%, 460px);
    height:auto;
    display:block;
    margin:0 auto 22px;
  }
  .hero .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    letter-spacing:.16em;
    font-size:12px;
    color:var(--red);
    text-transform:uppercase;
    display:inline-block;
    border:1px solid var(--border);
    padding:6px 16px;
    margin-bottom:20px;
    position:relative;
    z-index:1;
  }
  .hero p{
    font-family:'Cairo', sans-serif;
    font-weight:500;
    font-size:clamp(16px, 2.2vw, 19px);
    color:var(--text-muted);
    max-width:560px;
    margin:0 auto;
    position:relative;
    z-index:1;
  }

  /* ---------- specs ---------- */
  .specs{
    max-width:900px;
    margin:36px auto 0;
    padding:0 24px;
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    justify-content:center;
  }
  .specs .chip{
    font-family:'IBM Plex Mono', monospace;
    font-size:12.5px;
    color:var(--text-muted);
    border:1px solid var(--border);
    padding:8px 14px;
    background:var(--surface);
  }
  .specs .chip b{color:var(--red); font-weight:500;}

  /* ---------- form section ---------- */
  .form-wrap{
    max-width:660px;
    margin:56px auto 90px;
    padding:0 24px;
  }
  .ticket{
    background:var(--surface);
    border:1px solid var(--border);
    border-right:5px solid var(--red);
    padding:44px 36px;
  }
  .ticket h2{
    font-family:'Cairo', sans-serif;
    font-weight:800;
    font-size:28px;
    color:var(--white);
    margin-bottom:6px;
  }
  .ticket .sub{
    font-size:14px;
    color:var(--text-muted);
    margin-bottom:34px;
  }

  .field{margin-bottom:26px;}
  .field label{
    display:flex;
    align-items:baseline;
    gap:10px;
    font-size:15px;
    font-weight:500;
    margin-bottom:9px;
    color:var(--white);
  }
  .field label .no{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px;
    color:var(--red);
    letter-spacing:.05em;
  }
  .field input[type=text],
  .field input[type=tel],
  .field input[type=email],
  .field textarea{
    width:100%;
    background:var(--surface-2);
    border:1px solid var(--border);
    color:var(--white);
    font-family:'Tajawal', sans-serif;
    font-size:15px;
    padding:12px 14px;
    outline:none;
    transition:border-color .15s ease;
  }
  .field input:focus,
  .field textarea:focus{border-color:var(--red);}
  .field textarea{resize:vertical; min-height:90px;}
  .field .hint{font-size:12px; color:var(--text-muted); margin-top:6px;}

  /* file upload */
  .dropzone{
    border:1.5px dashed var(--border);
    padding:26px 16px;
    text-align:center;
    cursor:pointer;
    background:var(--surface-2);
    transition:border-color .15s ease;
    position:relative;
  }
  .dropzone.drag{border-color:var(--red);}
  .dropzone input[type=file]{position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%;}
  .dropzone .dz-icon{font-size:22px; margin-bottom:8px; color:var(--red);}
  .dropzone .dz-text{font-size:14px; color:var(--text-muted);}
  .dropzone .dz-file{font-family:'IBM Plex Mono', monospace; font-size:12.5px; color:var(--red); margin-top:10px; word-break:break-all;}

  .submit-btn{
    width:100%;
    background:var(--red);
    color:var(--white);
    border:none;
    padding:15px 20px;
    font-family:'Cairo', sans-serif;
    font-weight:800;
    font-size:16px;
    cursor:pointer;
    margin-top:12px;
    transition:background .15s ease, transform .1s ease;
  }
  .submit-btn:hover{background:var(--red-dark);}
  .submit-btn:active{transform:translateY(1px);}
  .submit-btn:disabled{background:var(--border); color:var(--text-muted); cursor:not-allowed;}

  .status{
    margin-top:18px;
    font-size:14px;
    padding:12px 14px;
    display:none;
  }
  .status.show{display:block;}
  .status.ok{background:rgba(60,150,90,.1); border:1px solid rgba(60,150,90,.4); color:#b9dfc4;}
  .status.err{background:rgba(226,33,27,.1); border:1px solid rgba(226,33,27,.45); color:#f3b8b5;}

  footer{
    text-align:center;
    padding:30px 24px 50px;
    font-family:'IBM Plex Mono', monospace;
    font-size:11.5px;
    color:var(--text-muted);
    letter-spacing:.04em;
    border-top:1px solid var(--border);
  }

  @media (max-width:520px){
    .ticket{padding:32px 20px;}
    .hero{padding:48px 18px 30px;}
  }
</style>
</head>
<body>

  <div class="accent-bar"></div>

  <section class="hero">
    <div class="arch"></div>
    <span class="eyebrow">استمارة تقديم الأعمال الفوتوغرافية</span>
    <div class="logo-wrap">
      <img class="logo" src="/assets/logo.png" alt="قوموا لله">
    </div>
    <p>شارِكنا عملك الفوتوغرافي عبر الاستمارة أدناه. تصل جميع الطلبات مباشرة وبشكل خاص، ولا يطّلع عليها أحد سوى فريق الإشراف.</p>
  </section>

  <div class="specs">
    <span class="chip">الصيغ المسموحة: <b>JPG · JPEG · PNG</b></span>
    <span class="chip">الحجم الأقصى: <b>20 MB</b></span>
    <span class="chip">الوصول: <b>خاص ومحمي</b></span>
  </div>

  <div class="form-wrap">
    <div class="ticket">
      <h2>بيانات التقديم</h2>
      <p class="sub">يرجى تعبئة جميع الحقول بدقة قبل إرسال الصورة.</p>

      <form id="submitForm" novalidate>
        <div class="field">
          <label><span class="no">01</span> الاسم الكامل</label>
          <input type="text" id="fullName" required placeholder="مثال: أحمد محمد علي">
        </div>

        <div class="field">
          <label><span class="no">02</span> رقم الهاتف</label>
          <input type="tel" id="phone" required placeholder="مثال: 07xxxxxxxxx">
        </div>

        <div class="field">
          <label><span class="no">03</span> البريد الإلكتروني</label>
          <input type="email" id="email" required placeholder="example@email.com">
        </div>

        <div class="field">
          <label><span class="no">04</span> المدينة / المحافظة</label>
          <input type="text" id="city" required placeholder="مثال: بغداد">
        </div>

        <div class="field">
          <label><span class="no">05</span> عنوان الصورة</label>
          <input type="text" id="title" required placeholder="عنوان العمل الفوتوغرافي">
        </div>

        <div class="field">
          <label><span class="no">06</span> وصف مختصر للصورة</label>
          <textarea id="description" required placeholder="اكتب وصفاً موجزاً عن الصورة وفكرتها..."></textarea>
        </div>

        <div class="field">
          <label><span class="no">07</span> رفع الصورة</label>
          <div class="dropzone" id="dropzone">
            <input type="file" id="photoFile" accept=".jpg,.jpeg,.png,image/jpeg,image/png" required>
            <div class="dz-icon">▣</div>
            <div class="dz-text">اضغط هنا أو اسحب الصورة لرفعها (JPG · JPEG · PNG)</div>
            <div class="dz-file" id="dzFileName"></div>
          </div>
          <div class="hint">لا يُسمح إلا بملفات JPG أو JPEG أو PNG.</div>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">إرسال الصورة</button>

        <div class="status" id="statusBox"></div>
      </form>
    </div>
  </div>

  <footer>قوموا لله — جميع الطلبات مشفّرة الوصول ولا تُعرض إلا لفريق الإشراف</footer>

<script>
  const form       = document.getElementById('submitForm');
  const dropzone   = document.getElementById('dropzone');
  const fileInput  = document.getElementById('photoFile');
  const dzFileName = document.getElementById('dzFileName');
  const submitBtn  = document.getElementById('submitBtn');
  const statusBox  = document.getElementById('statusBox');

  const ALLOWED_EXT = ['jpg', 'jpeg', 'png'];
  const MAX_SIZE_MB = 20;

  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) dzFileName.textContent = fileInput.files[0].name;
  });
  ['dragenter','dragover'].forEach(evt =>
    dropzone.addEventListener(evt, e => { e.preventDefault(); dropzone.classList.add('drag'); })
  );
  ['dragleave','drop'].forEach(evt =>
    dropzone.addEventListener(evt, e => { e.preventDefault(); dropzone.classList.remove('drag'); })
  );
  dropzone.addEventListener('drop', e => {
    if (e.dataTransfer.files[0]) {
      fileInput.files = e.dataTransfer.files;
      dzFileName.textContent = e.dataTransfer.files[0].name;
    }
  });

  function showStatus(msg, ok){
    statusBox.textContent = msg;
    statusBox.className = 'status show ' + (ok ? 'ok' : 'err');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    statusBox.className = 'status';

    const fullName = document.getElementById('fullName').value.trim();
    const phone    = document.getElementById('phone').value.trim();
    const email    = document.getElementById('email').value.trim();
    const city     = document.getElementById('city').value.trim();
    const title    = document.getElementById('title').value.trim();
    const desc     = document.getElementById('description').value.trim();
    const file     = fileInput.files[0];

    if (!fullName || !phone || !email || !city || !title || !desc || !file){
      showStatus('يرجى تعبئة جميع الحقول ورفع الصورة قبل الإرسال.', false);
      return;
    }
    const ext = file.name.split('.').pop().toLowerCase();
    if (!ALLOWED_EXT.includes(ext)){
      showStatus('صيغة الملف غير مدعومة. الصيغ المسموحة: JPG, JPEG, PNG فقط.', false);
      return;
    }
    if (file.size > MAX_SIZE_MB * 1024 * 1024){
      showStatus('حجم الملف كبير جداً. الحد الأقصى ' + MAX_SIZE_MB + ' ميغابايت.', false);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'جارٍ الإرسال...';

    try{
      const fd = new FormData();
      fd.append('fullName', fullName);
      fd.append('phone', phone);
      fd.append('email', email);
      fd.append('city', city);
      fd.append('title', title);
      fd.append('description', desc);
      fd.append('photo', file, file.name);

      const res = await fetch('/api/submit', { method: 'POST', body: fd });
      const data = await res.json();

      if (!data.ok) throw new Error(data.message || 'حدث خطأ غير متوقع');

      showStatus(data.message, true);
      form.reset();
      dzFileName.textContent = '';

    } catch(err){
      showStatus(err.message, false);
    } finally{
      submitBtn.disabled = false;
      submitBtn.textContent = 'إرسال الصورة';
    }
  });
</script>
</body>
</html>
